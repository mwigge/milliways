FROM fedora:39

ARG GO_VERSION=1.26.2

RUN dnf install -y git ca-certificates curl tar gzip \
    && curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" -o /tmp/go.tgz \
    && rm -rf /usr/local/go \
    && tar -C /usr/local -xzf /tmp/go.tgz \
    && rm -f /tmp/go.tgz \
    && dnf clean all

ENV PATH="/usr/local/go/bin:${PATH}"

WORKDIR /app
COPY . .

RUN go build -o /usr/local/bin/milliwaysctl ./cmd/milliwaysctl/

CMD ["bash", "tests/smoke/run_smoke.sh", "--no-docker"]
