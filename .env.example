# milliways — environment variable reference
#
# Copy this file to .env and fill in the values you need, or export the
# variables in your shell profile.  All variables are optional unless
# otherwise noted.
#
# Variables written automatically by install.sh / install_feature_deps.sh
# are marked accordingly — you normally do not need to set those manually.

# ── AI Provider API Keys ──────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=         # Claude runner (required for claude/codex runner)
# GEMINI_API_KEY=            # Gemini runner
# GOOGLE_API_KEY=            # Alias for GEMINI_API_KEY
# OPENAI_API_KEY=            # OpenAI-compatible runners
# MINIMAX_API_KEY=           # MiniMax runner
# CODES_API_KEY=             # GitHub Copilot runner

# ── AI Provider Model Overrides ──────────────────────────────────────────────
# ANTHROPIC_MODEL=           # Override default Claude model
# CLAUDE_MODEL=              # Alias for ANTHROPIC_MODEL
# CODEX_MODEL=               # Override default Codex model
# COPILOT_MODEL=             # Override default Copilot model
# GEMINI_MODEL=              # Override default Gemini model
# GOOGLE_MODEL=              # Alias for GEMINI_MODEL
# MINIMAX_MODEL=             # Override default MiniMax model
# OPENAI_MODEL=              # Override default OpenAI-compatible model

# ── Local Model Server ───────────────────────────────────────────────────────
# MILLIWAYS_LOCAL_ENDPOINT=http://localhost:8080   # Local server URL (llama.cpp / llama-swap / ollama / vllm)
# MILLIWAYS_LOCAL_MODEL=                           # Default model name for local runner
# MILLIWAYS_LOCAL_API_KEY=                         # API key if local server requires one
# MILLIWAYS_LOCAL_TEMP=0.7                         # Sampling temperature (set via /local-temp)
# MILLIWAYS_LOCAL_MAX_TOKENS=4096                  # Max output tokens (set via /local-max-tokens)
# MILLIWAYS_LOCAL_TOOLS=1                          # Enable tool use for local runner
# MODEL_DIR=~/.local/share/milliways/models        # Where GGUF models are stored

# ── Observability ────────────────────────────────────────────────────────────
# MILLIWAYS_OTEL_ENDPOINT=http://localhost:4318    # OTLP endpoint (Jaeger, Tempo, Grafana)
# MILLIWAYS_OTEL_PROTOCOL=http                    # http (default) or grpc

# ── Project Memory (MemPalace) ────────────────────────────────────────────────
# MILLIWAYS_MEMPALACE_MCP_CMD=~/.local/share/milliways/python/bin/python
# MILLIWAYS_MEMPALACE_MCP_ARGS=-m mempalace.mcp_server --palace ~/.mempalace
# Written automatically by install.sh / install_feature_deps.sh

# ── Code Intelligence (CodeGraph) ─────────────────────────────────────────────
# MILLIWAYS_CODEGRAPH_MCP_CMD=~/.local/share/milliways/node/bin/codegraph
# MILLIWAYS_CODEGRAPH_MCP_ARGS=serve
# MILLIWAYS_CODEGRAPH_WORKSPACE=                  # Indexed workspace path (set by milliwaysctl codegraph index)
# Written automatically by install.sh / install_feature_deps.sh

# ── Agent Toolkit ────────────────────────────────────────────────────────────
# MILLIWAYS_AGENTS_DIR=~/.local/share/milliways/agent-toolkit
# MILLIWAYS_RULES_DIR=~/.config/milliways/rules
# Written automatically by install_feature_deps.sh

# ── Security / Workspace ────────────────────────────────────────────────────
# MILLIWAYS_WORKSPACE_ROOT=              # Jail for file/bash tools (default: cwd)
# MILLIWAYS_PRIVATE_ROOTS=              # Extra directories to deny (colon-separated)
# MILLIWAYS_COMPANY_ROOTS=              # Roots to expose for company-wide tools
# MILLIWAYS_TOOLS_ALLOW_LOOPBACK=0     # Set to 1 to allow WebFetch to loopback (dev only)

# ── Runtime Tuning ──────────────────────────────────────────────────────────
# MILLIWAYS_MAX_TURNS=32               # Max agentic loop iterations
# MILLIWAYS_PATH=                      # Extra PATH entries (set via /path)
# MILLIWAYS_REPL=0                     # Force REPL mode (no wezterm launcher)
# MILLIWAYS_IN_COCKPIT=0              # Set by wezterm; do not set manually
# MILLIWAYSCTL_BIN=                    # Override milliwaysctl binary path
# MINIMAX_API_URL=                     # Override MiniMax API base URL
# MINIMAX_ENDPOINT=                    # Override MiniMax endpoint path
# MILLIWAYS_LOCAL_API_KEY=            # API key for local inference server
# MILLIWAYS_DELEGATE_SCRIPT=          # Override delegate.sh path
